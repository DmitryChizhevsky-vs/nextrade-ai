# ============================================================
# NexTrade AI Reporting Assistant — environment variables
# Copy this file to .env and fill in real values.
# ============================================================

# --- Database -----------------------------------------------
# Postgres connection string. For Vercel, use Vercel Postgres / Neon.
# For local dev, the easiest is a free Neon project (same URL works
# in both places). Docker: run `docker run --name nextrade-pg -e POSTGRES_PASSWORD=postgres -p 5432:5432 -d postgres:16`
# and use: postgresql://postgres:postgres@localhost:5432/nextrade
DATABASE_URL="postgresql://user:password@host:5432/nextrade?sslmode=require"

# --- LLM ----------------------------------------------------
# Get a key at https://console.anthropic.com (starter credits included).
ANTHROPIC_API_KEY="sk-ant-..."

# Model to use. Haiku is cheap and fast enough for text-to-SQL;
# switch to sonnet-4-5 if you want higher quality.
ANTHROPIC_MODEL="claude-haiku-4-5"
